{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fuc|if|else|elif|con\\s+loop|won\\s+loop)\\b.*:\\s*$",
    "decreaseIndentPattern": "^\\s*(else|elif)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(fuc|if|else|elif|con\\s+loop|won\\s+loop)\\b.*:\\s*$",
      "action": { "indent": "indent" }
    }
  ]
}
