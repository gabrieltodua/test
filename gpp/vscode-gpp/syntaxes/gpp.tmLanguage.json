{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "G++",
  "scopeName": "source.gpp",
  "fileTypes": ["G++", "g++"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings_double" },
    { "include": "#strings_single" },
    { "include": "#keywords_structure" },
    { "include": "#keywords_loop" },
    { "include": "#keywords_flow" },
    { "include": "#keywords_declaration" },
    { "include": "#builtin_output" },
    { "include": "#builtin_math" },
    { "include": "#builtin_random" },
    { "include": "#builtin_string" },
    { "include": "#builtin_list" },
    { "include": "#builtin_type" },
    { "include": "#builtin_time" },
    { "include": "#constants_bool" },
    { "include": "#constants_math" },
    { "include": "#numeric_literals" },
    { "include": "#operators_comparison" },
    { "include": "#operators_logical" },
    { "include": "#operators_arithmetic" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.number-sign.gpp",
      "match": "#.*$"
    },

    "strings_double": {
      "name": "string.quoted.double.gpp",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.gpp", "match": "\\\\." }
      ]
    },

    "strings_single": {
      "name": "string.quoted.single.gpp",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "name": "constant.character.escape.gpp", "match": "\\\\." }
      ]
    },

    "keywords_structure": {
      "name": "keyword.control.structure.gpp",
      "match": "\\b(if|else|elif|fuc|in)\\b"
    },

    "keywords_loop": {
      "patterns": [
        { "name": "keyword.control.loop.gpp", "match": "\\bcon\\s+loop\\b" },
        { "name": "keyword.control.loop.gpp", "match": "\\bwon\\s+loop\\b" }
      ]
    },

    "keywords_flow": {
      "name": "keyword.control.flow.gpp",
      "match": "\\b(rt|stop|skip)\\b"
    },

    "keywords_declaration": {
      "name": "keyword.other.declaration.gpp",
      "match": "\\b(make|set)\\b"
    },

    "builtin_output": {
      "name": "support.function.output.gpp",
      "match": "\\b(say|ask|clear_screen)(?=\\s*\\()"
    },

    "builtin_math": {
      "name": "support.function.math.gpp",
      "match": "\\b(sig|pa|di|abso|sqrt|floor|ceil|rnd|avg|total|clamp|even|odd|pow_of)(?=\\s*\\()"
    },

    "builtin_random": {
      "name": "support.function.random.gpp",
      "match": "\\b(chance|dice|pick|shuffle)(?=\\s*\\()"
    },

    "builtin_string": {
      "name": "support.function.string.gpp",
      "match": "\\b(upper|lower|trim|split|join|replace|has|startswith|endswith|repeat|flip|chars|pad|padleft|padright|numwords|cut_str)(?=\\s*\\()"
    },

    "builtin_list": {
      "name": "support.function.list.gpp",
      "match": "\\b(add|cut|ind|del|cler|sort|rev|copy|howmany|flat|first|last|slice_list|unique|zip_lists|insert|merge)(?=\\s*\\()"
    },

    "builtin_type": {
      "name": "support.function.type.gpp",
      "match": "\\b(rank|tonum|totext|tolist|isnull|isnum|istext|islist)(?=\\s*\\()"
    },

    "builtin_time": {
      "name": "support.function.time.gpp",
      "match": "\\b(wait|now|today)(?=\\s*\\()"
    },

    "constants_bool": {
      "name": "constant.language.boolean.gpp",
      "match": "\\b(TAR|FYU|NULL)\\b"
    },

    "constants_math": {
      "name": "constant.language.math.gpp",
      "match": "\\b(PI|E)\\b"
    },

    "numeric_literals": {
      "patterns": [
        { "name": "constant.numeric.float.gpp",   "match": "\\b[0-9]+\\.[0-9]+\\b" },
        { "name": "constant.numeric.integer.gpp",  "match": "\\b[0-9]+\\b" }
      ]
    },

    "operators_comparison": {
      "name": "keyword.operator.comparison.gpp",
      "match": "(==|!=|>=|<=|>|<)"
    },

    "operators_logical": {
      "name": "keyword.operator.logical.gpp",
      "match": "(\\s&\\s|\\s\\|\\s|(?<![=!<>])!(?!=))"
    },

    "operators_arithmetic": {
      "name": "keyword.operator.arithmetic.gpp",
      "match": "(\\^|\\*|/|\\+|-|%)"
    }
  }
}
