{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "G++",
  "scopeName": "source.gpp",
  "fileTypes": ["G++", "g++"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings_double" },
    { "include": "#strings_single" },
    { "include": "#keywords_structure" },
    { "include": "#keywords_loop" },
    { "include": "#keywords_flow" },
    { "include": "#keywords_declaration" },
    { "include": "#builtin_output" },
    { "include": "#builtin_math" },
    { "include": "#builtin_random" },
    { "include": "#builtin_string" },
    { "include": "#builtin_list" },
    { "include": "#builtin_box" },
    { "include": "#builtin_type" },
    { "include": "#builtin_time" },
    { "include": "#builtin_file" },
    { "include": "#constants_bool" },
    { "include": "#constants_math" },
    { "include": "#numeric_literals" },
    { "include": "#operators_comparison" },
    { "include": "#operators_logical" },
    { "include": "#operators_arithmetic" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.number-sign.gpp",
      "match": "#.*$"
    },
    "strings_double": {
      "name": "string.quoted.double.gpp",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.gpp", "match": "\\\\." }
      ]
    },
    "strings_single": {
      "name": "string.quoted.single.gpp",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "name": "constant.character.escape.gpp", "match": "\\\\." }
      ]
    },
    "keywords_structure": {
      "name": "keyword.control.structure.gpp",
      "match": "\\b(if|else|elif|fuc|in)\\b"
    },
    "keywords_loop": {
      "patterns": [
        { "name": "keyword.control.loop.gpp", "match": "\\bcon\\s+loop\\b" },
        { "name": "keyword.control.loop.gpp", "match": "\\bwon\\s+loop\\b" }
      ]
    },
    "keywords_flow": {
      "name": "keyword.control.flow.gpp",
      "match": "\\b(rt|stop|skip)\\b"
    },
    "keywords_declaration": {
      "name": "keyword.other.declaration.gpp",
      "match": "\\b(make|set)\\b"
    },
    "builtin_output": {
      "name": "support.function.output.gpp",
      "match": "\\b(say|ask|clear_screen|say_color|print_line)(?=\\s*\\()"
    },
    "builtin_math": {
      "name": "support.function.math.gpp",
      "match": "\\b(sig|pa|di|abso|sqrt|floor|ceil|rnd|avg|total|clamp|even|odd|pow_of|sign|percent|format_num|to_bin|to_hex|log|log10|sin|cos|tan|is_between|parse_int|parse_float)(?=\\s*\\()"
    },
    "builtin_random": {
      "name": "support.function.random.gpp",
      "match": "\\b(chance|dice|pick|shuffle|sample)(?=\\s*\\()"
    },
    "builtin_string": {
      "name": "support.function.string.gpp",
      "match": "\\b(upper|lower|trim|split|join|replace|has|startswith|endswith|repeat|flip|chars|pad|padleft|padright|numwords|cut_str|cap|title_case|count_char|remove_spaces|is_upper|is_lower|is_alpha|is_digit_str|strip_left|strip_right|find_in|slice_str)(?=\\s*\\()"
    },
    "builtin_list": {
      "name": "support.function.list.gpp",
      "match": "\\b(add|cut|ind|del|cler|sort|rev|copy|howmany|flat|first|last|slice_list|unique|zip_lists|insert|merge|range_list|fill|take|skip_items|chunk|without|any_true|all_true|count_if_true|nums_only|texts_only|sample)(?=\\s*\\()"
    },
    "builtin_box": {
      "name": "support.function.box.gpp",
      "match": "\\b(box|put|get_val|drop_key|has_key|keys_of|vals_of|pairs_of|box_size|merge_boxes|to_json|from_json|to_json_line)(?=\\s*\\()"
    },
    "builtin_type": {
      "name": "support.function.type.gpp",
      "match": "\\b(rank|tonum|totext|tolist|isnull|isnum|istext|islist|isbox|is_empty|parse_int|parse_float)(?=\\s*\\()"
    },
    "builtin_time": {
      "name": "support.function.time.gpp",
      "match": "\\b(wait|now|today|timestamp|time_ms)(?=\\s*\\()"
    },
    "builtin_file": {
      "name": "support.function.file.gpp",
      "match": "\\b(read_file|write_file|append_file|read_lines|file_exists)(?=\\s*\\()"
    },
    "constants_bool": {
      "name": "constant.language.boolean.gpp",
      "match": "\\b(TAR|FYU|NULL|INF|TAU)\\b"
    },
    "constants_math": {
      "name": "constant.language.math.gpp",
      "match": "\\b(PI|E)\\b"
    },
    "numeric_literals": {
      "patterns": [
        { "name": "constant.numeric.float.gpp",   "match": "\\b[0-9]+\\.[0-9]+\\b" },
        { "name": "constant.numeric.integer.gpp",  "match": "\\b[0-9]+\\b" }
      ]
    },
    "operators_comparison": {
      "name": "keyword.operator.comparison.gpp",
      "match": "(==|!=|>=|<=|>|<)"
    },
    "operators_logical": {
      "name": "keyword.operator.logical.gpp",
      "match": "(\\s&\\s|\\s\\|\\s|(?<![=!<>])!(?!=))"
    },
    "operators_arithmetic": {
      "name": "keyword.operator.arithmetic.gpp",
      "match": "(\\^|\\*|/|\\+|-|%)"
    }
  }
}
